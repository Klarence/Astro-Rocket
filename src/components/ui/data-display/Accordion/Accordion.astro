---
/**
 * Accordion Component
 * Accessible accordion with expand/collapse functionality
 */
import type { HTMLAttributes } from 'astro/types';
import { cn } from '@/lib/cn';

interface AccordionItemProps {
  question: string;
  answer: string;
  defaultOpen?: boolean;
}

interface Props extends HTMLAttributes<'div'> {
  items: AccordionItemProps[];
  variant?: 'default' | 'bordered';
}

const {
  items,
  variant = 'default',
  class: className,
  ...attrs
} = Astro.props;

const accordionClasses = cn(
  'flex flex-col gap-2',
  variant === 'bordered' && 'divide-y divide-border',
  className
);
---

<div class={accordionClasses} {...attrs}>
  {items.map((item, index) => (
    <div class="accordion-item">
      <h3>
        <button
          class="accordion-trigger w-full flex items-start justify-between gap-4 text-left py-4 text-base font-medium text-foreground hover:text-brand-500 transition-colors"
          aria-expanded="false"
          aria-controls={`accordion-content-${index}`}
        >
          <span>{item.question}</span>
          <span class="accordion-icon shrink-0 mt-0.5 text-foreground-muted transition-transform duration-200">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
      </h3>
      <div
        id={`accordion-content-${index}`}
        class="accordion-content hidden"
        role="region"
        aria-labelledby={`accordion-trigger-${index}`}
      >
        <p class="text-foreground-muted pb-4 leading-relaxed">
          {item.answer}
        </p>
      </div>
    </div>
  ))}
</div>

<script>
  function initAccordion() {
    const triggers = document.querySelectorAll<HTMLElement>('.accordion-trigger');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        const content = document.getElementById(trigger.getAttribute('aria-controls'));
        const icon = trigger.querySelector<HTMLElement>('.accordion-icon');

        trigger.setAttribute('aria-expanded', String(!isExpanded));

        if (content) {
          content.classList.toggle('hidden');
        }

        if (icon) {
          icon.style.transform = isExpanded ? 'rotate(0deg)' : 'rotate(180deg)';
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initAccordion);
  initAccordion();
</script>
